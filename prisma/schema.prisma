generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model House {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  people    Person[]
  rooms     Room[]
  taskTemplates TaskTemplate[]

}

model Person {
  id       String           @id @default(uuid())
  username String
  email    String
  phone    String?
  houseId  String
  house    House            @relation(fields: [houseId], references: [id])
  tasks    TaskAssignment[]
}

model Room {
  id      String @id @default(uuid())
  name    String
  houseId String
  house   House  @relation(fields: [houseId], references: [id])
  tasks   Task[]
}

model Task {
  id          String           @id @default(uuid())
  title       String
  desc        String
  tools       String[]
  howto       String
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  roomId      String
  descImages  String[]
  howtoImages String[]
  toolImages  String[]
  room        Room             @relation(fields: [roomId], references: [id])
  assignedTo  TaskAssignment[]
}

model TaskAssignment {
  taskId   String
  personId String
  person   Person @relation(fields: [personId], references: [id])
  task     Task   @relation(fields: [taskId], references: [id])

  @@id([taskId, personId])
}

// prisma/schema.prisma
model TaskTemplate {
  id          String   @id @default(uuid())
  title       String
  desc        String
  tools       String[]
  howto       String
  descImages  String[]
  toolImages  String[]
  howtoImages String[]
  house       House    @relation(fields: [houseId], references: [id])
  houseId     String
}